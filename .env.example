# Slack Agent Bridge - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets

# ============================================
# REQUIRED - Must be set for the agent to run
# ============================================

# Slack bot OAuth token (xoxb-...). NEVER log this.
SLACK_BOT_TOKEN=xoxb-your-token-here

# Channel ID for #claude-bridge (task intake channel)
BRIDGE_CHANNEL_ID=C0123456789

# Channel ID for #sqtools-ops (operations/status channel)
OPS_CHANNEL_ID=C0123456789

# ============================================
# OPTIONAL - Have sensible defaults
# ============================================

# Default GitHub organization for repo clones
# Default: jtpets
GITHUB_ORG=jtpets

# Path to claude CLI binary
# Default: /home/jtpets/.local/bin/claude
CLAUDE_BIN=/home/jtpets/.local/bin/claude

# Slack polling interval in milliseconds
# Default: 30000 (30 seconds)
POLL_INTERVAL_MS=30000

# Maximum Claude Code turns per task
# Default: 50
MAX_TURNS=50

# Task execution timeout in milliseconds
# Default: 600000 (10 minutes)
TASK_TIMEOUT_MS=600000

# Base directory for temporary repo clones
# Default: /tmp/bridge-agent
WORK_DIR=/tmp/bridge-agent

# ============================================
# AUTO-UPDATE - For auto-update.js daemon
# ============================================

# Path to the local repository for auto-updates
# Default: /home/jtpets/jt-agent
LOCAL_REPO_DIR=/home/jtpets/jt-agent

# Git polling interval for updates in milliseconds
# Default: 300000 (5 minutes)
CHECK_INTERVAL_MS=300000

# PM2 process name to restart on updates
# Default: bridge-agent
PM2_PROCESS_NAME=bridge-agent
