# Slack Agent Bridge - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets

# ============================================
# REQUIRED - Must be set for the agent to run
# ============================================

# Slack bot OAuth token (xoxb-...). NEVER log this.
# Required scopes: channels:history, channels:read, channels:manage, channels:join,
#                  chat:write, reactions:write, reactions:read, users:read
# Configure scopes at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here

# Channel ID for #claude-bridge (task intake channel)
BRIDGE_CHANNEL_ID=C0123456789

# Channel ID for #sqtools-ops (operations/status channel)
OPS_CHANNEL_ID=C0123456789

# ============================================
# OPTIONAL - Have sensible defaults
# ============================================

# Default GitHub organization for repo clones
# Default: jtpets
GITHUB_ORG=jtpets

# Path to claude CLI binary
# Default: /home/jtpets/.local/bin/claude
CLAUDE_BIN=/home/jtpets/.local/bin/claude

# Slack polling interval in milliseconds
# Default: 30000 (30 seconds)
POLL_INTERVAL_MS=30000

# Maximum Claude Code turns per task
# Default: 50
MAX_TURNS=50

# Task execution timeout in milliseconds
# Default: 600000 (10 minutes)
TASK_TIMEOUT_MS=600000

# Base directory for temporary repo clones
# Default: /tmp/bridge-agent
WORK_DIR=/tmp/bridge-agent

# ============================================
# AUTO-UPDATE - For auto-update.js daemon
# ============================================

# Path to the local repository for auto-updates
# Default: /home/jtpets/jt-agent
LOCAL_REPO_DIR=/home/jtpets/jt-agent

# Git polling interval for updates in milliseconds
# Default: 300000 (5 minutes)
CHECK_INTERVAL_MS=300000

# PM2 process name to restart on updates
# Default: bridge-agent
PM2_PROCESS_NAME=bridge-agent

# ============================================
# GOOGLE CALENDAR - For calendar integration
# ============================================

# Option 1: Service account authentication
# Path to Google service account JSON key file
# GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json

# Option 2: OAuth authentication (requires all three)
# GOOGLE_CALENDAR_REFRESH_TOKEN=your-refresh-token
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Comma-separated list of calendar IDs to fetch events from
# Default: primary (the user's primary calendar)
# GOOGLE_CALENDAR_IDS=primary,work@group.calendar.google.com

# ============================================
# LLM PROVIDERS - For multi-provider support
# ============================================

# LLM provider to use (default: claude)
# Options: claude, gemini, openai (not yet implemented), ollama (not yet implemented)
# LLM_PROVIDER=claude

# Google Gemini API key (required if using gemini provider)
# Get from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# HTTPSMS - Primary SMS provider (free)
# ============================================
# Uses owner's Android phone with httpSMS app installed.
# Customers see real local phone number. No monthly cost.
# Get API key at: https://httpsms.com

# httpSMS API key (required for SMS features). NEVER log this.
# HTTPSMS_API_KEY=your-httpsms-api-key-here

# Phone number with httpSMS app installed (+1234567890 format)
# HTTPSMS_PHONE_NUMBER=+1234567890
